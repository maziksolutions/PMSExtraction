# ============================================================
# Maritime PMS Data Extraction Tool — Backend Environment
# ============================================================
# Copy this file to .env and fill in real values before running.
# Never commit .env to source control.

# --- Application ---
PROJECT_NAME="Maritime PMS Data Extraction Tool"
VERSION="1.0.0"
API_V1_STR="/api/v1"

# --- Security (REQUIRED) ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_HOURS=8

# --- Database (REQUIRED) ---
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://pms_user:pms_password_dev@localhost:5432/pms_extraction

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Azure AD / Microsoft Identity (SharePoint OAuth) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
SHAREPOINT_REDIRECT_URI=http://localhost:3000/auth/sharepoint/callback

# --- Tenancy ---
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- MinIO (local dev blob storage — S3-compatible) ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=pms-manuals

# --- Azure Blob Storage (production — leave blank to use MinIO in dev) ---
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=pms-manuals

# --- Azure AI Translator ---
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com

# --- Azure AI Document Intelligence (Form Recognizer) ---
AZURE_DOC_INTELLIGENCE_KEY=
AZURE_DOC_INTELLIGENCE_ENDPOINT=

# --- AI / LLM ---
# Leave blank to use mock responses in development
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4.1-mini
ANTHROPIC_API_KEY=
CLAUDE_MODEL_ID=claude-sonnet-4-6
GEMINI_API_KEY=
GROQ_API_KEY=
EXTRACTION_MAX_TOKENS=8192
EXTRACTION_CHUNK_CHARS=14000
EXTRACTION_CHUNK_OVERLAP_CHARS=500

# --- CORS ---
ALLOWED_ORIGINS=["http://localhost:3000"]

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=100

# --- Seed Admin (used by scripts/seed_admin.py) ---
SEED_ADMIN_EMAIL=admin@unionmaritime.com
SEED_ADMIN_PASSWORD=ChangeMe1234!
SEED_ADMIN_FULL_NAME=System Administrator
SEED_TENANT_ID=00000000-0000-0000-0000-000000000001
